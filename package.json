{
  "name": "az-finance-hub",
  "version": "2.6.0",
  "private": true,
  "description": "A.Z Finance Hub v2 — Personal Sukuk & Fixed-Income Portfolio Management System",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "guard": "node scripts/guards/run-all.mjs",
    "guard:run-all": "node scripts/guards/run-all.mjs",
    "guard:no-frontend-finance-calculations": "node scripts/guards/check-no-frontend-finance-calculations.mjs",
    "guard:no-random-ui-libraries": "node scripts/guards/check-no-random-ui-libraries.mjs",
    "guard:dashboard-metrics-source": "node scripts/guards/check-dashboard-metrics-source.mjs",
    "guard:no-tofixed": "node scripts/guards/check-no-tofixed.mjs",
    "guard:protected-routes": "node scripts/guards/check-protected-routes.mjs",
    "guard:no-hardcoded-ui-strings": "node scripts/guards/check-no-hardcoded-ui-strings.mjs",
    "guard:no-direct-date-formatting": "node scripts/guards/check-no-direct-date-formatting.mjs",
    "guard:enforce:partial": "node scripts/guards/enforce-partial.mjs",
    "db:generate": "node scripts/run-with-dotenv-local.mjs drizzle-kit generate",
    "db:push:unsafe": "node scripts/run-with-dotenv-local.mjs drizzle-kit push --force",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.60.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "framer-motion": "^11.13.1",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.453.0",
    "next": "15.0.7",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "recharts": "^2.15.2",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}

  "framework": "nextjs",
  "regions": ["sin1"],
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "functions": {
    "app/api/dashboard/summary/route.ts": {
      "maxDuration": 60
    },
    "app/api/dashboard/metrics/route.ts": {
      "maxDuration": 60
    },
    "app/api/investments/route.ts": {
      "maxDuration": 60
    },
    "app/api/cashflows/route.ts": {
      "maxDuration": 60
    }
  }
}

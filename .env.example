# App runtime
# Next.js dev defaults to 3000. In production hosts like Vercel set this automatically.
PORT=3000

# Public app origin.
# The API is same-origin in this project, so there is no separate API_URL variable.
# Local:  http://localhost:3000
# Staging: https://azhub.uk
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase Auth (public browser-safe values)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres connection used by Drizzle, route handlers, migrations, and seeds.
# Prefer the Supabase session pooler connection string (port 5432).
DATABASE_URL=postgresql://postgres.xxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Single allowed owner login email.
OWNER_EMAIL=you@example.com

# The owner PIN/password is configured manually inside Supabase Auth.
# Do not store the real PIN in this file or in the repository.

# Optional future-use secret. Share links currently rely on random tokens.
SHARE_LINK_SECRET=change-me-random-32-bytes
